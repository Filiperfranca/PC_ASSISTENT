# ============================================================
# PRESENCE AGENT - EXAMPLE CONFIG
# Copy this file to .env and adjust local values.
# ============================================================

# ------------------------------------------------------------
# Camera
# ------------------------------------------------------------
CAMERA_INDEX=0
CAMERA_BACKEND=DSHOW

FRAME_WIDTH=640
FRAME_HEIGHT=480
TARGET_FPS=10

# ------------------------------------------------------------
# Face Detection
# ------------------------------------------------------------
DETECTION_PROCESS_EVERY_N_FRAMES=3
FACE_DETECTED_STREAK=4
FACE_LOST_STREAK=9

# ------------------------------------------------------------
# Presence
# ------------------------------------------------------------
FACE_LOST_GRACE_SECONDS=12
USER_AWAY_SECONDS=30
USER_PRESENT_CONFIRM_SECONDS=3

# ------------------------------------------------------------
# Windows Actions
# ------------------------------------------------------------
ENABLE_SYSTEM_ACTIONS=True
ENABLE_WINDOWS_LOCK=False
WINDOWS_LOCK_COOLDOWN_SECONDS=120

# ------------------------------------------------------------
# Debug / Logs
# ------------------------------------------------------------
DEBUG_MODE=False
LOG_LEVEL=INFO
ENABLE_DEBUG_WINDOW=False

# ------------------------------------------------------------
# Health
# ------------------------------------------------------------
ENABLE_HEALTH_SERVICE=True
HEALTH_CHECK_INTERVAL_SECONDS=30

# ------------------------------------------------------------
# Face Recognition
# ------------------------------------------------------------
ENABLE_FACE_RECOGNITION=True
AUTHORIZED_USER=authorized_user

RECOGNITION_AUTHORIZED_THRESHOLD=55
RECOGNITION_UNKNOWN_THRESHOLD=65
RECOGNITION_PROCESS_EVERY_N_EVENTS=1

MIN_AUTHORIZED_FACE_WIDTH=150

# Legacy/fallback.
RECOGNITION_CONFIDENCE_THRESHOLD=80

# ------------------------------------------------------------
# Security
# ------------------------------------------------------------
ENABLE_SECURITY_SERVICE=True

UNKNOWN_LOCK_ENABLED=False
UNKNOWN_CONFIRM_SECONDS=2
UNKNOWN_EVENT_STREAK=2
MIN_SECURITY_FACE_WIDTH=150
AUTHORIZED_GRACE_SECONDS=5

MULTI_FACE_WARNING_ENABLED=True
MULTI_FACE_CONFIRM_SECONDS=3
MULTI_FACE_PROMPT_COOLDOWN_SECONDS=120
MULTI_FACE_AUTO_LOCK_ON_TIMEOUT=False

# ------------------------------------------------------------
# Teams Integration
# ------------------------------------------------------------
# Providers:
# mock  - logs what would happen
# graph - uses Microsoft Graph, requires tenant permissions
ENABLE_TEAMS_INTEGRATION=False
TEAMS_PROVIDER=mock

TEAMS_TENANT_ID=
TEAMS_CLIENT_ID=
TEAMS_USER_ID=me
TEAMS_SESSION_ID=

TEAMS_PRESENCE_EXPIRATION=PT15M
TEAMS_KEEPALIVE_SECONDS=240

TEAMS_SET_AVAILABLE_ON_PRESENT=True
TEAMS_SET_AWAY_ON_AWAY=True

TEAMS_AVAILABLE_AVAILABILITY=Available
TEAMS_AVAILABLE_ACTIVITY=Available

TEAMS_AWAY_AVAILABILITY=Away
TEAMS_AWAY_ACTIVITY=Away

# ------------------------------------------------------------
# Startup Assistant
# ------------------------------------------------------------
ENABLE_STARTUP_ASSISTANT=True
STARTUP_REQUIRE_AUTHORIZED_USER=True
STARTUP_RUN_ONCE_PER_SESSION=True

STARTUP_GREETING_ENABLED=True
STARTUP_GREETING_MODE=log
STARTUP_GREETING_MESSAGE=Olá, bem-vindo de volta.

STARTUP_OPEN_APPS_ENABLED=True
STARTUP_APPS_CONFIG=app/config/startup_apps.json
STARTUP_APP_DELAY_SECONDS=1.5